# Base de datos (Supabase)
# Obtené la URL en: supabase.com → Tu proyecto → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# NextAuth
# Generá un secret con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-super-seguro-aqui"
NEXTAUTH_URL="http://localhost:3000"

# Uploadthing (para subir archivos PDF/Excel)
# Obtené las claves en: uploadthing.com
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="..."

# En producción (Vercel), NEXTAUTH_URL se setea automáticamente
# NEXTAUTH_URL="https://tu-app.vercel.app"
