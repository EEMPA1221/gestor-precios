generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
  READONLY
}

enum ListStatus {
  PENDING
  REVIEWING
  ACTIVE
  ARCHIVED
}

enum IvaRate {
  NONE
  TEN_FIVE
  TWENTY_ONE
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          Role     @default(OPERATOR)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  priceLists    PriceList[]
  productAliases ProductAlias[]
  comparisons   Comparison[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  phone     String?
  email     String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceLists PriceList[]

  @@map("suppliers")
}

model PriceList {
  id           String     @id @default(cuid())
  supplierId   String
  uploadedById String
  listDate     DateTime
  fileName     String?
  fileUrl      String?
  status       ListStatus @default(PENDING)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  supplier     Supplier   @relation(fields: [supplierId], references: [id])
  uploadedBy   User       @relation(fields: [uploadedById], references: [id])
  items        ListItem[]
  comparisonLists ComparisonList[]

  @@map("price_lists")
}

model MasterProduct {
  id           String  @id @default(cuid())
  internalName String
  category     String?
  brand        String?
  unit         String?
  code         String?
  createdAt    DateTime @default(now())

  listItems    ListItem[]
  aliases      ProductAlias[]

  @@map("master_products")
}

model ListItem {
  id              String        @id @default(cuid())
  listId          String
  masterProductId String?
  originalName    String
  presentation    String?
  costPrice       Decimal       @db.Decimal(12, 2)
  ivaRate         IvaRate       @default(NONE)
  notes           String?
  matched         Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  priceList       PriceList     @relation(fields: [listId], references: [id], onDelete: Cascade)
  masterProduct   MasterProduct? @relation(fields: [masterProductId], references: [id])

  @@map("list_items")
}

model ProductAlias {
  id              String        @id @default(cuid())
  masterProductId String
  aliasName       String
  createdById     String
  createdAt       DateTime      @default(now())

  masterProduct   MasterProduct @relation(fields: [masterProductId], references: [id])
  createdBy       User          @relation(fields: [createdById], references: [id])

  @@unique([masterProductId, aliasName])
  @@map("product_aliases")
}

model Comparison {
  id          String   @id @default(cuid())
  name        String?
  type        String   // "suppliers" | "versions"
  createdById String
  createdAt   DateTime @default(now())

  createdBy   User     @relation(fields: [createdById], references: [id])
  lists       ComparisonList[]

  @@map("comparisons")
}

model ComparisonList {
  comparisonId String
  listId       String

  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  priceList    PriceList  @relation(fields: [listId], references: [id])

  @@id([comparisonId, listId])
  @@map("comparison_lists")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("config")
}
